# App base URL (used for badge/proof links; falls back to VERCEL_URL on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# NextAuth base URL (required for OAuth redirect URLs)
NEXTAUTH_URL=http://localhost:3000

# Database — app runtime (least-privilege role, DML only)
DATABASE_URL=postgresql://prs_app:password@host/neondb?sslmode=require

# Database — migrations only (owner role, used by drizzle-kit push/migrate)
DATABASE_URL_OWNER=postgresql://neondb_owner:password@host/neondb?sslmode=require

# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_GITHUB_ID=your-github-oauth-app-id
AUTH_GITHUB_SECRET=your-github-oauth-app-secret

# Encryption key for user API keys at rest (32 bytes, base64)
ENCRYPTION_KEY=generate-with-openssl-rand-base64-32

# Shared secret for GitHub Action → prs.md API calls (generate with: openssl rand -hex 32)
# Must also be set as a GitHub Actions secret named ACTION_SECRET
ACTION_SECRET=generate-with-openssl-rand-hex-32

# Rate limiting — Upstash Redis (https://console.upstash.com — free tier)
# Create a Redis database, then copy the REST URL and token from the dashboard.
# Without these the rate limiter is disabled (safe for local dev).
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Analytics (optional — omit to disable)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token

# Sentry error tracking (https://sentry.io — free tier)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
# Only needed for source map uploads in CI (optional)
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
